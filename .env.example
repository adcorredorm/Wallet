# Docker Compose Environment Variables
# Copy this file to .env and adjust values for your environment
# Docker Compose will automatically load variables from .env file

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_NAME=wallet_db
DB_USER=wallet_user
DB_PASSWORD=wallet_password
DB_PORT=5432

# ============================================================================
# FLASK APPLICATION CONFIGURATION
# ============================================================================
# Application environment: development, staging, production
FLASK_ENV=development

# Enable Flask debug mode (NEVER use in production)
DEBUG=True

# Secret key for Flask session management and CSRF protection
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# CORS origins - comma-separated list of allowed origins
# For development: allow localhost and container hostnames
FLASK_CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://frontend:80

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# API base URL for frontend requests
VITE_API_BASE_URL=http://localhost:5000

# ============================================================================
# AUTHENTICATION & AUTHORIZATION
# ============================================================================
# Google OAuth Client ID (public, safe to expose in frontend)
# Obtain from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here

# JWT secret key for token signing and verification
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER share this key or expose it in the frontend
JWT_SECRET=your-jwt-secret-key-here

# Frontend Google Client ID (same as GOOGLE_CLIENT_ID, public value)
# Copy the same value from GOOGLE_CLIENT_ID above — Vite requires its own prefixed variable.
# Used in frontend build to configure Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# ============================================================================
# PGADMIN CONFIGURATION (Development only)
# ============================================================================
PGADMIN_EMAIL=admin@wallet.local
PGADMIN_PASSWORD=admin

# ============================================================================
# PRODUCTION SETTINGS (Uncomment and configure for production deployment)
# ============================================================================
# FLASK_ENV=production
# DEBUG=False
# SECRET_KEY=<generate-secure-random-key>
# DATABASE_URL=<production-database-url>
# FLASK_CORS_ORIGINS=https://yourdomain.com
