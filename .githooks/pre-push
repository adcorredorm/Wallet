#!/usr/bin/env bash
set -uo pipefail

# Read push refs from stdin — format: <local-ref> <local-sha> <remote-ref> <remote-sha>
while read local_ref local_sha remote_ref remote_sha; do
    branch="${remote_ref#refs/heads/}"

    if [ "$branch" != "main" ]; then
        continue
    fi

    echo "🔄 Pre-push: corriendo migraciones contra producción..."

    # Verify flask is available
    if ! command -v flask &>/dev/null; then
        echo "❌ Error: flask no está en PATH. Activá el virtualenv o instalalo con: pip install flask flask-migrate"
        exit 1
    fi

    REPO_ROOT="$(git rev-parse --show-toplevel)"
    cd "$REPO_ROOT/backend"

    # Verify DATABASE_URL is set (required for production migrations)
    if [ -z "${DATABASE_URL:-}" ]; then
        # Try loading from .env (root or backend/)
        for envfile in "$REPO_ROOT/.env" "$REPO_ROOT/backend/.env"; do
            if [ -f "$envfile" ] && grep -qE '^DATABASE_URL=' "$envfile"; then
                export $(grep -E '^DATABASE_URL=' "$envfile" | xargs)
                break
            fi
        done
        if [ -z "${DATABASE_URL:-}" ]; then
            echo "❌ Error: DATABASE_URL no está definida. Verificá que backend/.env existe y tiene DATABASE_URL."
            exit 1
        fi
    fi

    # Run migrations via Flask-Migrate (uses backend/migrations/, matches production DB history)
    set +e
    migration_output=$(FLASK_APP=run:app flask db upgrade 2>&1)
    exit_code=$?
    set -e

    if [ $exit_code -ne 0 ]; then
        echo "❌ Migraciones fallaron. Push abortado."
        echo "$migration_output"
        exit 1
    fi

    # Count applied migrations (Flask-Migrate logs: "Running upgrade <rev> -> <rev>, <msg>")
    applied=$(echo "$migration_output" | grep -c "Running upgrade" || true)

    if [ "$applied" -eq 0 ]; then
        echo "✓ Migraciones: sin cambios (ya en head)"
    else
        echo "✓ Migraciones: $applied aplicadas correctamente"
    fi

    # Verify DB is actually at Alembic head
    set +e
    current_output=$(FLASK_APP=run:app flask db current 2>&1)
    head_output=$(FLASK_APP=run:app flask db heads 2>&1)
    set -e

    # Extract just the revision hash (strip INFO lines, "(head)" suffix, whitespace)
    current_rev=$(echo "$current_output" | grep -v "^INFO" | head -1 | sed 's/ (head)//' | xargs)
    head_rev=$(echo "$head_output" | grep -v "^INFO" | head -1 | sed 's/ (head)//' | xargs)

    if [ "$current_rev" != "$head_rev" ]; then
        echo "❌ DB no está en head después de upgrade."
        echo "   Current: $current_rev"
        echo "   Head:    $head_rev"
        echo "   Push abortado. Corré 'flask db upgrade' manualmente y verificá."
        exit 1
    fi

    echo "✓ DB verificada en head: $current_rev"
done

exit 0
