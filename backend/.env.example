# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Authentication & Authorization
# Google OAuth Client ID - obtain from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
# JWT secret for token signing - generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-jwt-secret-key-here

# Database Configuration
DATABASE_URL=postgresql://wallet_user:wallet_password@localhost:5432/wallet_db

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
