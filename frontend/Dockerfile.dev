# Development Dockerfile for Vue.js with Vite
# Provides hot module reload (HMR) for rapid development
# Usage: docker-compose -f docker-compose.yml -f docker-compose.dev.yml up

FROM node:20-alpine

# Install dumb-init to properly handle signals
# This ensures the container responds correctly to SIGTERM and SIGINT
RUN apk add --no-cache dumb-init

# Set working directory
WORKDIR /app

# Copy package files for dependency installation
COPY package.json package-lock.json ./

# Install dependencies using ci for reproducible builds
RUN npm ci

# Copy application source code
COPY . .

# Expose Vite dev server port
EXPOSE 5173 5174

# Health check - verify Vite dev server is responding
HEALTHCHECK --interval=15s --timeout=5s --start-period=15s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:5173/ || exit 1

# Use dumb-init to handle signals properly
ENTRYPOINT ["dumb-init", "--"]

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
