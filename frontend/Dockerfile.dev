# Development Dockerfile for Vue.js with Vite
# Provides hot module reload (HMR) for rapid development
# Usage: docker-compose -f docker-compose.yml -f docker-compose.dev.yml up

FROM node:20-alpine

# Install dumb-init to properly handle signals
# This ensures the container responds correctly to SIGTERM and SIGINT
RUN apk add --no-cache dumb-init

# Set working directory
WORKDIR /app

# Copy only package.json (not package-lock.json).
# The package-lock.json may contain resolved URLs pointing to corporate/private registries
# (e.g. nexus.corp.indeed.com) that are not accessible from inside Docker containers.
# By omitting it, npm install resolves packages fresh from the public registry.
COPY package.json ./

# Install dependencies using the public npm registry.
# --registry overrides any host-level .npmrc registry settings.
RUN npm install --registry https://registry.npmjs.org

# Copy application source code
COPY . .

# Expose Vite dev server port
EXPOSE 5173 5174

# Health check - verify Vite dev server is responding
HEALTHCHECK --interval=15s --timeout=5s --start-period=15s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:5173/ || exit 1

# Use dumb-init to handle signals properly
ENTRYPOINT ["dumb-init", "--"]

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
