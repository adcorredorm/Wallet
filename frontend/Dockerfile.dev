# Development Dockerfile for Vue.js with Vite
# Provides hot module reload (HMR) for rapid development
# Usage: docker-compose -f docker-compose.yml -f docker-compose.dev.yml up

FROM node:20-alpine

# Install dumb-init to properly handle signals
# This ensures the container responds correctly to SIGTERM and SIGINT
RUN apk add --no-cache dumb-init

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json package-lock.json* yarn.lock* ./

# Install dependencies
# Using npm ci with package-lock.json ensures reproducible installs
# Falls back to yarn or npm install if lockfile doesn't exist
RUN if [ -f yarn.lock ]; then \
      yarn install; \
    elif [ -f package-lock.json ]; then \
      npm ci; \
    else \
      npm install; \
    fi

# Copy application source code
# Note: node_modules will be excluded via docker-compose volume mounts
COPY . .

# Expose Vite dev server port
# Vite dev server typically runs on 5173
EXPOSE 5173 5174

# Health check - verify Vite dev server is responding
# Vite returns HTML content even on /
HEALTHCHECK --interval=15s --timeout=5s --start-period=15s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:5173/ || exit 1

# Use dumb-init to handle signals properly
# This prevents zombie processes and ensures clean shutdown
ENTRYPOINT ["dumb-init", "--"]

# Run Vite dev server with HMR enabled
# The server will automatically reload on file changes
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
