# Development Environment Configuration
# This file is used when running in development mode (npm run dev)

# Backend API Configuration
# Development: Use full URL to backend since we're not using nginx proxy
VITE_API_BASE_URL=/api/v1

# Google OAuth Client ID — copy the same value from GOOGLE_CLIENT_ID in backend/.env.example
# Vite requires its own prefixed variable for build-time substitution.
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Environment
VITE_ENV=development
